# Allows other aliases to be sudo'd.
alias sudo='sudo '

# Replacements and aliases for built-in programs
alias ls='exa --group-directories-first '

# Convenience aliases
alias ll='ls -lh'
alias la='ls -lah'
alias l.='ls -lah | egrep "^\."'

# Prevent dangerous commands from silently running
alias cp='cp -i'

# Package Management
alias pacman-autoremove='sudo pacman -Rns $(pacman -Qdtq)'

# System Resources 
alias free='free -m'
alias storage='pydf -h / /home /run/media/ashish/Acer /run/media/ashish/Data'
alias battery="watch sudo tlp-stat -b"
alias pat="sudo powertop --auto-tune &> /dev/null"

# Development 
alias pyserver='python3 -m http.server'
alias mgd='mongod --dbpath=data --quiet --syslog --bind_ip=127.0.0.1 --port=27017 &'
alias code='code-oss '

# Git aliases
alias gs='git status'
alias gl='git lg'

# Network
alias ip-nat='hostname -i'
alias ip-public='wget -qO- http://ipecho.net/plain | xargs echo'
alias ping='ping -c 5'
alias wget='wget -c '

# Clipboard
alias cclip='xclip -selection clipboard'
alias cpaste='xclip -selection clipboard -o'

# Zsh Configurations
alias virc='vim ~/.zshrc'
alias vial='vim ~/.zsh_aliases'
alias vifn='vim ~/.zsh_functions'
alias viex='vim ~/.zsh_exports'

# Fun Ztuff
alias rr='curl -s -L https://raw.githubusercontent.com/keroserene/rickrollrc/master/roll.sh | bash'
