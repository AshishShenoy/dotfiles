# Reload sxhkdrc
super + shift + r
        pkill -usr1 -x sxhkd && notify-send 'sxhkd' 'Reloaded config'

super + Return
	alacritty

super + v
	code

super + b
	firefox

super + e
	dolphin

super + t
        source ~/.config/sxhkd/scripts/ocr.sh

super + d
	discord

super + m
	rhythmbox

super + s
	spotify

super + f
	flameshot gui
