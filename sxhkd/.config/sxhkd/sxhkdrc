# Reload sxhkdrc
super + shift + r
        pkill -usr1 -x sxhkd && notify-send 'sxhkd' 'Reloaded config'

super + Return
	alacritty

super + v
	code

super + b
	firefox

super + e
	dolphin

super + t
        source ~/.config/sxhkd/scripts/ocr.sh

super + c
        source ~/.config/sxhkd/scripts/placeholder.sh

super + shift + Return
        alacritty -e ssh ashish@atlas

super + d
	discord

super + r
        rofi -show drun

super + m
	rhythmbox

super + s
	spotify

super + f
	flameshot gui
